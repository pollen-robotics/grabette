# Casquette configuration — copy to `.env` and edit as needed.
#
# All settings are optional; unset keys fall back to the defaults in
# casquette/config.py. Every key is prefixed with CASQUETTE_ (the pydantic
# env_prefix). Unknown / mis-prefixed keys are ignored, not fatal.

# ── Server ──────────────────────────────────────────────────────────────
# CASQUETTE_HOST=0.0.0.0
# CASQUETTE_PORT=8001

# ── Backend ─────────────────────────────────────────────────────────────
# "auto" (default) picks rpi when picamera2 is importable, else mock.
# CASQUETTE_BACKEND=auto

# ── Multi-device sync ───────────────────────────────────────────────────
# Stable per-device id. Recorded into metadata.json and used to identify
# "self" within the rig topology. Falls back to the hostname if empty.
# CASQUETTE_DEVICE_ID=casquette-1

# Peer list for the /api/sync/{start,stop} fan-out. Comma-separated
# device_id=url pairs. When set, POSTing /api/sync/start preflight-checks
# each peer's NTP sync, picks a common T0, and starts every device (this
# one + all peers) in lockstep, rolling back on any failure. Empty (the
# default) makes the sync endpoints degrade to local-only.
#
# CASQUETTE_PEERS=grabette-1=http://rgrabette1.local:8000,grabette-2=http://rgrabette2.local:8000

# ── Logging ─────────────────────────────────────────────────────────────
# CASQUETTE_LOG_LEVEL=INFO
